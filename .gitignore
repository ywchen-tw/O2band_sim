# partition sums) is provided separately, consistent with excluding data/.
*.h5
*.hdf5
*.nc
*.npy
*.npz
*.pkl
*.bin
*.bin.ctl
*.QTpy
*.piz
*.par

# er3t / MCARaTS scratch run directories
tmp-data/
*.tmp

